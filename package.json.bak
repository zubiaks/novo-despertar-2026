{{
  "name": "novo-despertar",
  "version": "0.1.0",
  "description": "Site do Novo Despertar — textos, práticas e recursos para viver com presença",
  "private": true,
  "main": "public/index.html",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 5173",
    "serve": "http-server public -p 8080 -c-1",
    "lint": "eslint \"**/*.js\" --max-warnings=0",
    "format": "prettier --write \"**/*.{js,css,html,json,md}\"",
    "check:links": "broken-link-checker --recursive --no-robots --filter-level 3 http://localhost:8080",
    "test": "echo \"No tests configured\" && exit 0",
    "clean": "rimraf dist .cache",
    "deploy": "npm run build && gh-pages -d dist",
    "dev:server": "ts-node-dev --respawn --transpile-only src/server.ts"
  },
  "files": [
    "public",
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zubiaks/novo-despertar-2026.git"
  },
  "keywords": [
    "blog",
    "static-site",
    "novo-despertar"
  ],
  "author": "Pedro",
  "license": "MIT",
  "browserslist": [
    "defaults",
    "not IE 11",
    "maintained node versions"
  ],
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.3",
    "@types/uuid": "^10.0.0",
    "broken-link-checker": "^0.7.8",
    "eslint": "^8.50.0",
    "gh-pages": "^5.0.0",
    "http-server": "^14.1.1",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.0",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0"
  }
}
}
